# Connection string de Neon Postgres (Dashboard de Neon, seccion Connection Details).
# Solo la leen las Vercel Functions (/api) y el script de migraciones.
# NUNCA debe llegar al cliente: no usar prefijo VITE_ (Vite solo expone VITE_*).
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
